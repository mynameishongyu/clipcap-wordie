NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BROWSER_PROCESS_LOGS_ENABLED=true
NEXT_PUBLIC_PDF_RENDER_SCALE=6
NEXT_PUBLIC_PDF_RENDER_IMAGE_FORMAT=image/jpeg
NEXT_PUBLIC_PDF_RENDER_JPEG_QUALITY=0.92
NEXT_PUBLIC_PDF_AUTO_ROTATE_PAGES=true
NEXT_PUBLIC_PDF_PREVIEW_SHARPEN_STRENGTH=0.25
NEXT_PUBLIC_PDF_VISION_RENDER_CONCURRENCY=3
NEXT_PUBLIC_PDF_STORAGE_UPLOAD_CONCURRENCY=3
PDF_GEMINI_FILE_PIPELINE_CONCURRENCY=2
NEXT_PUBLIC_PDF_FILL_MAX_TASK_COUNT=3
# JSON preview debug toggle:
# This is controlled in the browser console, not by env vars.
# Use these commands on the slot-review / generation-review pages:
#   window.clipcapJsonPreview.show()
#   window.clipcapJsonPreview.hide()
#   window.clipcapJsonPreview.toggle()
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
TEXT_LLM_API_KEY=your_text_llm_api_key
TEXT_LLM_BASE_URL=https://your-text-llm-base-url.example.com/v1
TEXT_LLM_MODEL=your_text_llm_model
# Optional override when the model name is an endpoint id and does not reveal provider.
# Supported values: gemini, kimi, qwen, doubao, openai-compatible
# TEXT_LLM_PROVIDER=openai-compatible
TEXT_LLM_THINKING_ENABLED=false
TEXT_LLM_REASONING_EFFORT=medium
TEMPLATE_EXTRACTION_MIN_PARAGRAPH_CHARACTER_COUNT=6
TEMPLATE_EXTRACTION_LLM_CONCURRENCY=1
TEMPLATE_EXTRACTION_LLM_REQUEST_INTERVAL_MS=7000
TEMPLATE_EXTRACTION_LLM_MAX_RETRIES=4
# You can keep TEXT_LLM_* and VISION_LLM_* as separate variables
# even when both point to the same provider/model, for example Kimi:
# TEXT_LLM_API_KEY=your_moonshot_api_key
# TEXT_LLM_BASE_URL=https://api.moonshot.cn/v1
# TEXT_LLM_MODEL=kimi-k2.5
# If TEXT_LLM_MODEL or VISION_LLM_MODEL starts with gemini-, the app uses
# Gemini's OpenAI-compatible endpoint by model name. Prefer GEMINI_API_KEY.
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
VISION_LLM_API_KEY=your_vision_llm_api_key
VISION_LLM_BASE_URL=https://your-vision-llm-base-url.example.com/v1
VISION_LLM_MODEL=your_vision_llm_model
# Optional override when the model name is an endpoint id and does not reveal provider.
# Supported values: gemini, kimi, qwen, doubao, openai-compatible
# VISION_LLM_PROVIDER=openai-compatible
VISION_LLM_THINKING_ENABLED=false
VISION_LLM_REASONING_EFFORT=medium
TEMPLATE_PDF_LOCATION_LLM_CONCURRENCY=1
# PDF visual evidence bbox target mode:
# text = box only the visible value text; cell = box containing table cell/evidence region.
PDF_BBOX_TARGET_MODE=cell
# Number of parallel VISION_LLM requests for filling slots from new PDF pages.
# 1 means one request receives all uploaded PDF page images.
PDF_FILL_VISION_PAGES_LLM_CONCURRENCY=1
# Number of new PDF pages sent to VISION_LLM per page-filter request.
PDF_FILL_PAGE_FILTER_PAGES_PER_REQUEST=4
PDF_FILL_PAGE_FILTER_DROP_EXAMPLES_DIR=pdf_page_filter_drop_examples
# VISION_LLM_API_KEY=your_moonshot_api_key
# VISION_LLM_BASE_URL=https://api.moonshot.cn/v1
# VISION_LLM_MODEL=kimi-k2.5
